DATABASE_URL="postgresql://user:password@localhost:5432/coride?schema=public"
JWT_SECRET="your_jwt_secret_here"
PORT=5001

# Goong Maps API Keys
# Maps API Key - Dùng để hiển thị bản đồ trên frontend (bản đồ tiles)
NEXT_PUBLIC_GOONG_MAPTILES_KEY="your_goong_maptiles_key_here"

# REST API Key - Dùng cho các dịch vụ backend (geocoding, directions, autocomplete)
# Lưu ý: Key này được sử dụng trong backend, không cần NEXT_PUBLIC_
GOONG_REST_API_KEY="your_goong_rest_api_key_here"

